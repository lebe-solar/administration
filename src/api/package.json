{
  "name": "lebe-admin-api",
  "version": "0.1.0",
  "description": "LeBe Solarenergie — Product Administration REST API (Express on Azure Functions custom handler, Cosmos DB for MongoDB, Blob Storage uploads)",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prebuild": "npm run lint",
    "build": "tsc -b .",
    "prestart": "npm run build",
    "start": "node .",
    "test": "jest --coverage"
  },
  "author": "",
  "license": "UNLICENSED",
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "<rootDir>/**/*.spec.ts"
    ]
  },
  "dependencies": {
    "@azure/identity": "^4.2.1",
    "@azure/storage-blob": "^12.24.0",
    "config": "^3.3.12",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "mongoose": "^8.9.5",
    "multer": "^2.0.1",
    "swagger-ui-express": "^4.4.0",
    "winston": "^3.7.2",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.18.2",
    "@babel/preset-typescript": "^7.17.12",
    "@types/config": "^0.0.41",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/jest": "^28.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/yamljs": "^0.2.31",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "eslint": "^8.17.0",
    "jest": "^28.1.1",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^6.2.3",
    "ts-jest": "^28.0.4",
    "typescript": "^4.7.3"
  }
}
