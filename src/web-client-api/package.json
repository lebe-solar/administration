{
  "name": "lebe-web-client-api",
  "version": "0.1.0",
  "description": "LeBe Solarenergie — separate, public, read-only API for the SEO-oriented public WebClient (src/web-client). Reads public-safe data straight from Cosmos DB. Not the Admin API: different auth (none — everything here is intentionally public) and different data-exposure rules (no Draft/Hidden content, no admin-only fields).",
  "main": "dist/server.js",
  "scripts": {
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prebuild": "npm run lint",
    "build": "tsc -b .",
    "dev": "ts-node src/server.ts",
    "prestart": "npm run build",
    "start": "node .",
    "test": "jest --coverage"
  },
  "author": "",
  "license": "UNLICENSED",
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "<rootDir>/**/*.spec.ts"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.18.2",
    "@babel/preset-typescript": "^7.17.12",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/jest": "^28.1.1",
    "@types/node": "^20.11.28",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "eslint": "^8.17.0",
    "jest": "^28.1.1",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^6.2.3",
    "ts-jest": "^28.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^4.7.3"
  }
}
